    "login:browser": "node src/vsllm-auto.js --login-browser",
    "run": "node src/vsllm-auto.js",
    "run:headed": "node src/vsllm-auto.js --headed",
    "api": "node src/vsllm-api.js",
    "api:balance": "node src/vsllm-api.js --balance",
    "api:watch": "node src/vsllm-api.js --watch",
    "api:headed": "node src/vsllm-api.js --headed",
    "watch": "node src/vsllm-auto.js --watch",
    "watch:headed": "node src/vsllm-auto.js --watch --headed"
